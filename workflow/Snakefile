import os
from pathlib import Path

# config
NUM_CPUS = 8

# paths
WORKFLOW_DIR = Path(workflow.basedir)
DATA_DIR = WORKFLOW_DIR / "data"
ASIM_OUT_DIR = DATA_DIR / "asim_out"

# Final output
rule all:
    input:
        str(ASIM_OUT_DIR / "DONE")
    default_target: True


# 1. Download reference
rule download_reference:
    output:
        directory("data/reference/Homo_sapiens_GRCh38_Ensembl115")
    conda:
        "envs/reference.yaml"
    shell:
        "bash scripts/download_reference_ensembl.sh '{output}'"


# 2. Run ASimulatoR
rule run_asimulator:
    input:
        rules.download_reference.output
    output:
        str(ASIM_OUT_DIR / "DONE")
    container:
        "docker://biomedbigdata/asimulator"
    shell:
        """
        mkdir -p {ASIM_OUT_DIR}
        Rscript scripts/runASimulatoR.R {input} {ASIM_OUT_DIR}
        touch {output}
        """


