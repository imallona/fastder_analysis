import os
from pathlib import Path

# config (edit here if needed)
REF_VERSION = "hg38"
NUM_CPUS = 8
PROJECT_NAME = "asim"
PROJECT_ID = 101

# paths
WORKFLOW_DIR = Path(workflow.basedir)
DATA_DIR = WORKFLOW_DIR / "data"
ASIM_OUT_DIR = DATA_DIR / "asim_out"
MONORAIL_REF_DIR = DATA_DIR / "monorail_refs"
PUMP_INPUT_DIR = DATA_DIR / "pump_input"
PUMP_OUTPUT_DIR = DATA_DIR / "pump_output"
UNIFY_WORK_DIR = DATA_DIR / "unify_work"
FASTDER_INPUT_DIR = DATA_DIR / "fastder_input"

CONTAINERS_DIR = WORKFLOW_DIR / "containers"
PUMP_SIF = str(CONTAINERS_DIR / "recount-pump-1.1.3.sif")
UNIFY_SIF = str(CONTAINERS_DIR / "recount-unify-1.1.1.sif")

MONORAIL_EXTERNAL = WORKFLOW_DIR / "external" / "monorail-external"


# Helper functions
def get_asim_dirs():
    """Find sample directories in ASimulatoR output."""
    if not ASIM_OUT_DIR.exists():
        return []
    dirs = []
    for entry in ASIM_OUT_DIR.iterdir():
        if entry.is_dir() and entry.name != "DONE":
            if list(entry.glob("*_1.fastq")):
                dirs.append(entry.name)
    return dirs


def get_all_pump_outputs(wildcards):
    checkpoint_output = checkpoints.discover_samples.get().output[0]
    with open(checkpoint_output) as f:
        samples = [line.strip().split('\t')[0] for line in f if line.strip()]
    return expand(str(PUMP_OUTPUT_DIR / "{sample}_att0" / "DONE"), sample=samples)


# Final output
rule all:
    input:
        str(FASTDER_INPUT_DIR / "DONE")
    default_target: True


# 1. Download reference
rule download_reference:
    output:
        directory("data/reference/Homo_sapiens_GRCh38_Ensembl115")
    conda:
        "envs/reference.yaml"
    shell:
        "bash scripts/download_reference_ensembl.sh '{output}'"


# 2. Run ASimulatoR
rule run_asimulator:
    input:
        rules.download_reference.output
    output:
        str(ASIM_OUT_DIR / "DONE")
    container:
        "docker://biomedbigdata/asimulator"
    shell:
        """
        mkdir -p {ASIM_OUT_DIR}
        Rscript scripts/runASimulatoR.R {input} {ASIM_OUT_DIR}
        touch {output}
        """


# 3. Checkpoint: discover samples and create simple IDs
checkpoint discover_samples:
    input:
        str(ASIM_OUT_DIR / "DONE")
    output:
        str(DATA_DIR / "samples.txt")
    run:
        asim_dirs = get_asim_dirs()
        with open(output[0], 'w') as f:
            for i, dirname in enumerate(sorted(asim_dirs), 1):
                simple_id = f"sample_{i:02d}"
                f.write(f"{simple_id}\t{dirname}\n")
        print(f"Discovered {len(asim_dirs)} samples")


# 4. Pull Singularity containers
rule pull_containers:
    output:
        pump = PUMP_SIF,
        unify = UNIFY_SIF
    params:
        containers_dir = str(CONTAINERS_DIR)
    shell:
        """
        mkdir -p {params.containers_dir}
        cd {params.containers_dir}
        singularity pull --name recount-pump-1.1.3.sif docker://quay.io/broadsword/recount-pump:1.1.3
        singularity pull --name recount-unify-1.1.1.sif docker://quay.io/broadsword/recount-unify:1.1.1
        """


# 5. Download Monorail references
rule download_monorail_refs:
    output:
        str(MONORAIL_REF_DIR / "refs.DONE")
    params:
        ref_dir = str(MONORAIL_REF_DIR),
        monorail = str(MONORAIL_EXTERNAL)
    shell:
        """
        mkdir -p {params.ref_dir}
        cd {params.ref_dir}
        bash {params.monorail}/get_human_ref_indexes.sh
        bash {params.monorail}/get_unify_refs.sh {REF_VERSION}
        touch {output}
        """


# 6. Prepare input: copy FASTQs to simple-named directory
rule prepare_input:
    input:
        samples = str(DATA_DIR / "samples.txt")
    output:
        str(PUMP_INPUT_DIR / "{sample}" / "input.DONE")
    params:
        sample = "{sample}",
        asim_dir = str(ASIM_OUT_DIR),
        input_dir = str(PUMP_INPUT_DIR),
        samples_file = str(DATA_DIR / "samples.txt")
    run:
        import shutil
        
        # find original directory name from samples.txt
        original_name = None
        with open(params.samples_file) as f:
            for line in f:
                parts = line.strip().split('\t')
                if parts[0] == params.sample:
                    original_name = parts[1]
                    break
        
        if not original_name:
            raise ValueError(f"Sample {params.sample} not found in samples.txt")
        
        original_dir = Path(params.asim_dir) / original_name
        target_dir = Path(params.input_dir) / params.sample
        target_dir.mkdir(parents=True, exist_ok=True)
        
        # copy FASTQ files
        for fq in original_dir.glob("*.fastq"):
            dest = target_dir / fq.name
            if not dest.exists():
                shutil.copy2(fq, dest)
        
        Path(output[0]).touch()


# 7. Run recount-pump per sample
rule run_pump:
    input:
        input_done = str(PUMP_INPUT_DIR / "{sample}" / "input.DONE"),
        refs = str(MONORAIL_REF_DIR / "refs.DONE"),
        container = PUMP_SIF
    output:
        str(PUMP_OUTPUT_DIR / "{sample}_att0" / "DONE")
    params:
        sample = "{sample}",
        input_dir = str(PUMP_INPUT_DIR),
        pump_out = str(PUMP_OUTPUT_DIR),
        ref_dir = str(MONORAIL_REF_DIR),
        monorail = str(MONORAIL_EXTERNAL),
        pump_sif = PUMP_SIF,
        ref_version = REF_VERSION,
        project_name = PROJECT_NAME
    threads: NUM_CPUS
    shell:
        """
        SAMPLE_DIR="{params.input_dir}/{params.sample}"
        FASTQ1="$SAMPLE_DIR/sample_01_1.fastq"
        FASTQ2="$SAMPLE_DIR/sample_01_2.fastq"
        
        mkdir -p {params.pump_out}
        cd {params.pump_out}
        
        bash {params.monorail}/singularity/run_recount_pump.sh \
            {params.pump_sif} \
            {params.sample} \
            local \
            {params.ref_version} \
            {threads} \
            {params.ref_dir} \
            "$FASTQ1" \
            "$FASTQ2" \
            {params.project_name}
        
        mkdir -p {params.pump_out}/{params.sample}_att0
        touch {output}
        """


# 8. Create metadata for unify
rule create_metadata:
    input:
        get_all_pump_outputs
    output:
        str(UNIFY_WORK_DIR / "sample_metadata.tsv")
    params:
        pump_dir = str(PUMP_OUTPUT_DIR),
        project_name = PROJECT_NAME
    run:
        os.makedirs(os.path.dirname(output[0]), exist_ok=True)
        samples = [d.replace("_att0", "") for d in os.listdir(params.pump_dir) 
                   if d.endswith("_att0") and os.path.isdir(os.path.join(params.pump_dir, d))]
        with open(output[0], 'w') as f:
            f.write("study_id\tsample_id\n")
            for s in sorted(samples):
                f.write(f"{params.project_name}\t{s}\n")
        print(f"Created metadata for {len(samples)} samples")


# 9. Run recount-unify
rule run_unify:
    input:
        metadata = rules.create_metadata.output,
        refs = str(MONORAIL_REF_DIR / "refs.DONE"),
        container = UNIFY_SIF
    output:
        str(UNIFY_WORK_DIR / "DONE")
    params:
        ref_dir = str(MONORAIL_REF_DIR),
        work_dir = str(UNIFY_WORK_DIR),
        pump_dir = str(PUMP_OUTPUT_DIR),
        monorail = str(MONORAIL_EXTERNAL),
        unify_sif = UNIFY_SIF,
        ref_version = REF_VERSION,
        project_name = PROJECT_NAME,
        project_id = PROJECT_ID
    threads: NUM_CPUS
    shell:
        """
        mkdir -p {params.work_dir}
        
        bash {params.monorail}/singularity/link_unifier_input_from_pump_output.sh \
            {params.pump_dir} \
            {params.work_dir}/linked_input
        
        bash {params.monorail}/singularity/run_recount_unify.sh \
            {params.unify_sif} \
            {params.ref_version} \
            {params.ref_dir} \
            {params.work_dir} \
            {params.work_dir}/linked_input \
            {input.metadata} \
            {threads} \
            {params.project_name}:{params.project_id}
        
        touch {output}
        """


# 10. Extract files for FASTDER
rule extract_fastder_inputs:
    input:
        unify_done = str(UNIFY_WORK_DIR / "DONE"),
        samples_file = str(DATA_DIR / "samples.txt")
    output:
        str(FASTDER_INPUT_DIR / "DONE")
    params:
        fastder_dir = str(FASTDER_INPUT_DIR),
        unify_dir = str(UNIFY_WORK_DIR),
        pump_output = str(PUMP_OUTPUT_DIR),
        asim_out = str(ASIM_OUT_DIR),
        samples_file = str(DATA_DIR / "samples.txt"),
        project_name = PROJECT_NAME,
        ref_version = REF_VERSION
    run:
        import shutil
        import subprocess
        import gzip
        from pathlib import Path

        fastder_dir = Path(params.fastder_dir)
        fastder_dir.mkdir(parents=True, exist_ok=True)

        # 1. Copy and gunzip unified/aggregate files (MM, RR)
        junction_dir = Path(params.unify_dir) / "junction_counts_per_study" / "im" / params.project_name

        mm_gz_file = junction_dir / f"{params.project_name}.junctions.{params.project_name}.ALL.MM.gz"
        rr_gz_file = junction_dir / f"{params.project_name}.junctions.{params.project_name}.ALL.RR.gz"

        # Gunzip MM file
        mm_output = fastder_dir / f"{params.project_name}.junctions.{params.project_name}.ALL.MM"
        with gzip.open(mm_gz_file, 'rb') as f_in:
            with open(mm_output, 'wb') as f_out:
                shutil.copyfileobj(f_in, f_out)

        # Gunzip RR file
        rr_output = fastder_dir / f"{params.project_name}.junctions.{params.project_name}.ALL.RR"
        with gzip.open(rr_gz_file, 'rb') as f_in:
            with open(rr_output, 'wb') as f_out:
                shutil.copyfileobj(f_in, f_out)

        # 2. Process each sample - copy files to flat directory with clear naming
        with open(params.samples_file) as f:
            for line in f:
                if not line.strip():
                    continue
                simple_id, original_name = line.strip().split('\t')

                # Copy bigWig file from pump output to flat directory
                pump_sample_dir = Path(params.pump_output) / "output" / f"{simple_id}_att0"

                # The bigWig filename pattern: sample_01!asim!hg38!local.all.bw (exclude unmapped)
                bigwig_file = pump_sample_dir / f"{simple_id}!{params.project_name}!{params.ref_version}!local.all.bw"
                bigwig_output = fastder_dir / f"{simple_id}.all.bw"

                shutil.copy2(bigwig_file, bigwig_output)

                # Copy GTF file from ASimulatoR output to flat directory
                asim_sample_dir = Path(params.asim_out) / original_name
                gtf_file = asim_sample_dir / "splicing_variants.gtf"
                gtf_output = fastder_dir / f"{simple_id}_splicing_variants.gtf"

                shutil.copy2(gtf_file, gtf_output)

        print(f"FASTDER input extraction complete. Files organized in flat structure at {fastder_dir}")

        # 3. Generate BigWig list CSV
        subprocess.run(["bash", "./scripts/create_bigwig_list.sh"], check=True)

        # Create DONE file
        Path(output[0]).touch()
