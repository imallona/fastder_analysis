        *([op.join(RESULTS_DIR, "gtex_concordance.html")]
          if BACKEND == "recount3" and R3_DATA_SOURCE == "gtex"
          else [op.join(RESULTS_DIR, "recount3.html")]
          if BACKEND == "recount3" else []),
        op.join(RESULTS_DIR, "archive.DONE"),
    default_target: True
