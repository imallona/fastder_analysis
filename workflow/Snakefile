import os
import os.path as op
import itertools
from pathlib import Path

# IMPORTANT: scenarios control whether ASimulatoR template transcripts contribute reads. template_and_variant keeps the default (template + variant both expressed); variant_only post-filters the FASTQ and GFF so the truth set carries only alternative isoforms.

# Default config is ../config/config.yaml; override with the FASTDER_EVAL_CONFIG
# environment variable to fully replace it (e.g. with config_quick.yaml for a
# reduced-scope local run). Using an env var instead of --configfile avoids the
# deep-merge that would otherwise union nested dicts like asimulator.samples.
_CFG_PATH = os.environ.get("FASTDER_EVAL_CONFIG", "../config/config.yaml")
CONFIG_BASENAME = op.splitext(op.basename(_CFG_PATH))[0]
configfile: _CFG_PATH

# Internal path constants.
WORKFLOW_DIR = workflow.basedir
DATA_DIR = op.join(WORKFLOW_DIR, "data")
LOG_DIR = op.join(WORKFLOW_DIR, "logs")
# Snakemake benchmark TSVs land under logs/benchmarks/<config>/. The config
# basename keeps per-config runtime numbers separated so that running a
# second config does not overwrite the first config's benchmark TSVs.
BENCH_DIR = op.join(LOG_DIR, "benchmarks", CONFIG_BASENAME)

# Monorail
MONORAIL_EXTERNAL = op.join(WORKFLOW_DIR, "external", "monorail-external")
MONORAIL_REF_DIR = op.join(DATA_DIR, "monorail_refs")

# Singularity images
CONTAINERS_DIR = op.join(WORKFLOW_DIR, "containers")
PUMP_SIF = op.join(CONTAINERS_DIR, "recount-pump-1.1.3.sif")
UNIFY_SIF = op.join(CONTAINERS_DIR, "recount-unify-1.1.1.sif")

# Backend: selects how the per-sample coverage BigWigs and the MM/RR splice
# junction files that fastder consumes are produced. All three backends end
# at the same inputs; they differ in how much processing the pipeline runs.
#
#   monorail
#     The full Monorail stack. Takes raw reads (FASTQ from ASimulatoR, or
#     downloaded from SRA) and runs recount-pump and recount-unify inside
#     Singularity containers: STAR alignment, BigWig coverage, junction
#     extraction, then aggregation across samples. Downloads the multi-GB
#     Monorail reference indexes on first use.
#
#   monorail_light
#     A lightweight stand-in for the Monorail stack. Takes the same raw reads
#     but runs a chromosome-restricted STAR alignment directly, then
#     emit_lean_mm_rr.py builds the lean MM/RR files from the STAR SJ.out.tab
#     outputs. No Singularity and no whole-genome reference download. Output
#     is restricted to fastder.chromosomes.
#
#   recount3
#     No read processing. Downloads coverage and junctions that the recount3
#     resource already holds, Monorail-processed, for a published SRA study,
#     and reshapes them per sample group. It does not align reads or run any
#     containers. See workflow/rules/recount3.smk.
BACKEND = config.get("monorail", {}).get("backend", "monorail")
if BACKEND not in ("monorail", "monorail_light", "recount3"):
    raise ValueError(
        f"Unknown monorail.backend: '{BACKEND}'. "
        "Must be 'monorail', 'monorail_light' or 'recount3'."
    )

# recount3 ingestion constants. The recount3 rules in rules/recount3.smk rely
# on these, and SCENARIOS / PUMP_SAMPLES below also reference them, so they
# must be defined before the include statements.
RECOUNT3_CFG = config.get("recount3") or {}
R3_STUDY = RECOUNT3_CFG.get("study_acc", "")
R3_BASE_URL = RECOUNT3_CFG.get("base_url", "http://duffel.rail.bio/recount3")
R3_METADATA_URL = RECOUNT3_CFG.get("metadata_url", "http://idies.jhu.edu/recount3/data")
R3_DIR = op.join(DATA_DIR, "recount3")

# recount3 data source: "sra" (default) or "gtex". It selects the
# data_sources/<source> path component and the "<source>." file-name prefix.
R3_DATA_SOURCE = RECOUNT3_CFG.get("data_source", "sra")

# groups maps a sample group to its samples. Two forms are accepted:
#   flat   {group: [sample, ...]}                one shared study_acc
#   nested {group: {study: <acc>, samples: [...]}}  a per-group study, for
#       multi-study collections such as per-tissue GTEx
# Both are normalised into a samples map (R3_GROUPS) and a per-group study map.
R3_GROUPS = {}
R3_GROUP_STUDY = {}
for _grp, _spec in (RECOUNT3_CFG.get("groups") or {}).items():
    if isinstance(_spec, dict):
        R3_GROUPS[_grp] = list(_spec["samples"])
        R3_GROUP_STUDY[_grp] = _spec["study"]
    else:
        R3_GROUPS[_grp] = list(_spec)
        R3_GROUP_STUDY[_grp] = R3_STUDY
# Flat list of every sample across all groups.
R3_ALL_SAMPLES = [s for runs in R3_GROUPS.values() for s in runs]
# sample -> study, so the per-sample BigWig URL can resolve its study.
R3_SAMPLE_STUDY = {s: R3_GROUP_STUDY[g] for g, ss in R3_GROUPS.items() for s in ss}


def _r3_shard(accession):
    """recount3 stores files in a directory named after the last two
    characters of the study accession."""
    return accession[-2:]


def _r3_sample_shard(sample):
    """Directory shard for a per-sample base_sums file: the last two
    characters of the sample id, after dropping a recount3 run suffix such
    as the '.1' that gtex external ids carry."""
    return sample.rsplit(".", 1)[0][-2:]


# fastder
FASTDER_DIR = op.join(DATA_DIR, "fastder")
FASTDER_BUILD_DIR = op.join(WORKFLOW_DIR, "external", "fastder", "build")
# Results live under a per-config subdirectory so multiple configs do not
# overwrite each other. Reruns of the same config keep going to the same
# place so snakemake's incremental machinery still works; old reports get
# preserved by the archive_reports rule below.
RESULTS_DIR = op.join(WORKFLOW_DIR, "results", CONFIG_BASENAME)

# monorail_light scratch
LIGHT_DIR = op.join(DATA_DIR, "monorail_light")

# Experimental design. The asimulator block is optional: configs that use the
# recount3, sra or local input do not need it.
ASIM_SAMPLES = list((config.get("asimulator") or {}).get("samples", {}).keys())

# Asimulator outputs are keyed on seq_depth so the depth-sweep configs do not
# overwrite each other and snakemake does not see a params change between
# consecutive runs of the same `make all`. Configs without an asimulator block
# still need ASIM_DIR defined so the rule files parse; the rule never fires
# there. The tag uses int() so a YAML float (1e7) and an int (10000000) map to
# the same directory.
_ASIM_SEQ_DEPTH = (config.get("asimulator") or {}).get("seq_depth", 0)
ASIM_DIR = op.join(DATA_DIR, "asim", f"depth_{int(_ASIM_SEQ_DEPTH)}")

# Per the IMPORTANT note above, every downstream stage runs once per scenario.
# The scenario axis depends on the input:
#   ASimulatoR input has the two template/variant scenarios.
#   recount3 input uses one scenario per sample group, so a knockdown group
#     and a control group stay separate (see config.recount3.groups).
#   SRA and local FASTQ input have no scenarios, so a single "all" scenario
#     is used.
#   The variant_only scenario needs the reads filtered, not just the truth
#   GFF. Only the monorail_light backend does that (ml_star_align reads the
#   per-scenario FASTQ). The heavy monorail backend aligns the unfiltered
#   FASTQ through a pump/unify step that is not scenario-aware, so it runs
#   template_and_variant only; otherwise variant_only would change the truth
#   set without changing the coverage and the comparison would be invalid.
_PUMP_SOURCE_EARLY = config.get("monorail", {}).get("pump_source", "asimulator")
if BACKEND == "recount3":
    SCENARIOS = list(R3_GROUPS.keys())
elif _PUMP_SOURCE_EARLY == "asimulator":
    SCENARIOS = (["template_and_variant", "variant_only"]
                 if BACKEND == "monorail_light"
                 else ["template_and_variant"])
else:
    SCENARIOS = ["all"]

# Tools to benchmark against fastder. Each tool produces a GTF at the
# standardised path data/tools/{tool}/{scenario}/{param_id}/output.gtf,
# which run_gffcompare and eval_fuzzy_metrics consume via the {tool}
# wildcard.
#
# Parameter equivalence across tools (only shared axes are swept):
#
#   fastder axis           megadepth_baseline           derfinder
#   --------------------   --------------------------   --------------------------
#   --min-coverage (CPM)   --cutoff (CPM)               --cutoff (CPM)
#   --min-length (bp)      --min-length (bp, post-flt)  --min-length (bp, post-flt)
#   --position-tolerance   (n/a)                        --maxregiongap (analogue)
#   --coverage-tolerance   (n/a)                        (n/a)
#
# All three tools normalise per-sample coverage to CPM before averaging,
# using the same library_size formula (Sum length * value over the user's
# chromosomes), so a given numeric --cutoff means the same thing
# everywhere. fastder's --position-tolerance allows a few bp of slack at
# SJ-anchored boundaries; derfinder's --maxregiongap bridges a few bp of
# below-threshold gap inside a region. The two are not identical, but
# both are tolerance settings in the bp dimension; sweeping both surfaces
# where they end up roughly comparable.
#
# Possible next additions: stringtie (no-reference assembler, BAM in
# -> GTF out, conda env: stringtie) and scallop (alternative assembler
# from BAM, conda env: scallop). They consume BAM rather than coverage
# tracks, so they don't share the --min-coverage axis with the three
# above; they would get their own grid.
# Defaults to all four. A config may set `tools:` to a subset, for example
# [fastder] for a fastder-only run with no baseline comparison.
#
# grohmm is an HMM segmenter (Chae et al. 2015), originally for GRO-seq but
# adopted on RNA-seq coverage by the TAR-scRNA-seq pipeline (Wang et al. 2021).
# Here we run it on the same unstranded coverage bigWigs as derfinder and the
# megadepth baseline, so the three tools share input shape and output
# stranding (all three emit unstranded calls on recount3 input).
_ALL_TOOLS = ["fastder", "derfinder", "megadepth_baseline", "grohmm"]
TOOLS = config.get("tools") or _ALL_TOOLS
for _t in TOOLS:
    if _t not in _ALL_TOOLS:
        raise ValueError(f"Unknown tool '{_t}' in config.tools; "
                         f"choose from {_ALL_TOOLS}.")

# Wildcard constraints keep snakemake from matching path components against
# unrelated wildcards (e.g. {sample} swallowing a scenario subdir).
wildcard_constraints:
    scenario="(" + "|".join(SCENARIOS) + ")",
    tool="(" + "|".join(TOOLS) + ")",
    sample="[^/]+",
    param_id="[^/]+",

# Pump source determines which samples and inputs the pump rule uses.
# The recount3 backend does not run the pump rule, so pump_source is optional
# there.
PUMP_SOURCE = config.get("monorail", {}).get("pump_source", "asimulator")
if BACKEND == "recount3":
    # Samples are the recount3 run accessions across all groups. The truth
    # set is the downloaded Ensembl annotation, a GTF.
    PUMP_SAMPLES = R3_ALL_SAMPLES
    LABEL_EXT = ".gtf"
elif PUMP_SOURCE == "asimulator":
    PUMP_SAMPLES = ASIM_SAMPLES
    LABEL_EXT = ".gff3"  # ASimulatoR always produces GFF3
elif PUMP_SOURCE == "sra":
    PUMP_SAMPLES = list(config["monorail"]["sra_samples"].keys())
    LABEL_EXT = ".gtf"
elif PUMP_SOURCE == "local":
    # Local FASTQ input: the same path as the SRA source, but the reads are
    # already on disk, so the download step is skipped. Each sample names its
    # paired FASTQ files under monorail.local_samples.
    PUMP_SAMPLES = list(config["monorail"]["local_samples"].keys())
    LABEL_EXT = ".gtf"
else:
    raise ValueError(
        f"Unknown pump_source: '{PUMP_SOURCE}'. "
        "Must be 'asimulator', 'sra' or 'local'."
    )

# Samples evaluated under each scenario. ASimulatoR runs evaluate each
# simulated sample against its own truth GFF. recount3, SRA and local runs
# are graded against the shared reference annotation, so the per-sample truth
# dimension collapses to a single pseudo-sample named "reference".
if BACKEND == "recount3" or PUMP_SOURCE in ("sra", "local"):
    SAMPLES_BY_SCENARIO = {scenario: ["reference"] for scenario in SCENARIOS}
else:
    SAMPLES_BY_SCENARIO = {scenario: PUMP_SAMPLES for scenario in SCENARIOS}

# True only when the run has a simulated per-sample truth set. recount3, SRA
# and local input are graded against the reference annotation instead.
HAS_SIM_TRUTH = (BACKEND != "recount3" and PUMP_SOURCE == "asimulator")

# fastder parameter grid: every combination of the configured lists is run.
# Each combo is a plain dict of {param_name: value} for explicitly-set params only.
# Omitted params are not passed to fastder, which uses its own internal defaults.
FASTDER_CFG = config.get("fastder") or {}
# TODO(deprecate): STRANDED=True is a hack not used by the paper. Every
# config in config/ sets stranded: false, and the three baseline runners
# collapse any stranded input into one unstranded vector per sample.
# Removing the stranded branches needs the original contributor's agreement.
STRANDED = FASTDER_CFG.get("stranded", False)

# Human reference download, keyed by chromosome scope. Configs that analyse
# different chromosome sets get independent, cacheable reference folders
# instead of clobbering one shared directory, and a chromosome-set change is
# the only thing that forces a fresh download. The rule declares explicit
# file outputs (the GTF and one FASTA per chromosome), never a directory:
# ASimulatoR caches an exon-superset .rda next to the GTF, and a directory
# output would let that write bump a directory mtime and re-trigger every
# consumer.
def _norm_chrom(c):
    c = str(c)
    return c if c.startswith("chr") else "chr" + c

_REF_CHROMS_CFG = FASTDER_CFG.get("chromosomes") or []
if _REF_CHROMS_CFG:
    REF_SCOPE = "_".join(sorted({_norm_chrom(c) for c in _REF_CHROMS_CFG},
                                key=lambda c: (len(c), c)))
else:
    REF_SCOPE = "full_genome"

REF_DIR = op.join(DATA_DIR, "reference", "GRCh38_Ensembl115_" + REF_SCOPE)
REF_CHROMS = [str(c).removeprefix("chr")
              for c in (_REF_CHROMS_CFG or [str(i) for i in range(1, 23)] + ["X"])]
REF_GTF = op.join(REF_DIR, "Homo_sapiens.GRCh38.115.chr.gtf")
REF_FASTAS = [op.join(REF_DIR, f"{c}.fa") for c in REF_CHROMS]

# Reference annotation used as the gffcompare truth set for real data
# (recount3, sra, local). It defaults to the downloaded GTF, so a config never
# has to track the scope-keyed reference path by hand; gffcompare.reference_
# annotation can still override it.
REF_ANNOTATION = (config.get("gffcompare") or {}).get("reference_annotation") or REF_GTF

# STAR index for the monorail_light backend, keyed by the same scope so a
# single-chromosome index and a whole-genome index never share a directory.
# Outputs are the files STAR genomeGenerate always writes, not a directory.
LIGHT_STAR_IDX = op.join(LIGHT_DIR, "star_idx_" + REF_SCOPE)
STAR_IDX_FILES = ["SA", "SAindex", "Genome", "chrNameLength.txt",
                  "genomeParameters.txt"]

# Maps each parameter name to its (id_abbreviation, CLI flag).
_PARAM_SPEC = {
    "min_coverage":       ("mc", "--min-coverage"),
    "min_length":         ("ml", "--min-length"),
    "position_tolerance": ("pt", "--position-tolerance"),
    "coverage_tolerance": ("ct", "--coverage-tolerance"),
}

# Cross-product of all configured value lists; {} means "run once with all defaults".
_grid_axes = [
    [(key, val) for val in FASTDER_CFG[key]]
    for key in _PARAM_SPEC
    if key in FASTDER_CFG
]
_PARAM_COMBOS = [dict(items) for items in itertools.product(*_grid_axes)] if _grid_axes else [{}]


def _param_id(combo):
    """Short, directory-safe identifier for a parameter combination."""
    abbr = {k: spec[0] for k, spec in _PARAM_SPEC.items()}
    parts = [f"{abbr[k]}{v}" for k, v in combo.items()]
    return "_".join(parts) if parts else "default"


def _fastder_cli_args(combo):
    """CLI flags to pass to fastder for this combination (only explicitly-set params)."""
    flag = {k: spec[1] for k, spec in _PARAM_SPEC.items()}
    return " ".join(f"{flag[k]} {v}" for k, v in combo.items())


PARAM_IDS = [_param_id(c) for c in _PARAM_COMBOS]
PARAM_CLI_ARGS = {_param_id(c): _fastder_cli_args(c) for c in _PARAM_COMBOS}
# For the summary CSV: the explicit params for each run
PARAM_DICT = {_param_id(c): c for c in _PARAM_COMBOS}

# Per-tool param grids. fastder sweeps the full cross-product above.
# megadepth_baseline shares the min_coverage axis only (its other tunable
# is min_length, which we pin to fastder.min_length[0] for symmetry).
# derfinder shares min_coverage and position_tolerance (mapped to
# --maxregiongap; see TOOLS comment for the mapping rationale).
def _baseline_mc_param_ids():
    mcs = FASTDER_CFG.get("min_coverage") or [0.05]
    return [f"mc{v}" for v in mcs]


def _baseline_mc_pt_param_ids():
    mcs = FASTDER_CFG.get("min_coverage") or [0.05]
    pts = FASTDER_CFG.get("position_tolerance") or [0]
    return [f"mc{mc}_pt{pt}" for mc in mcs for pt in pts]


def _parse_mc_pt(param_id):
    """Pull (mc, pt) numerics out of an mc<v>[_pt<v>] param_id."""
    import re
    mc_match = re.search(r"mc([0-9.]+)", param_id)
    pt_match = re.search(r"pt([0-9.]+)", param_id)
    mc = float(mc_match.group(1)) if mc_match else None
    pt = float(pt_match.group(1)) if pt_match else 0
    return mc, pt


# groHMM has its own parameters, not shared with the fastder grid. LtProbB is the
# log-prob of remaining in the transcribed state (more negative = stricter
# calling; default -200). UTS is the variance of the untranscribed state
# (default 5). Set via a top-level `grohmm:` block in the config, with these
# defaults if absent.
def _baseline_lp_uts_param_ids():
    grohmm_cfg = config.get("grohmm") or {}
    lps = grohmm_cfg.get("ltprobb") or [-200]
    utss = grohmm_cfg.get("uts") or [5]
    return [f"lp{lp}_uts{uts}" for lp in lps for uts in utss]


def _parse_lp_uts(param_id):
    """Pull (LtProbB, UTS) numerics out of a lp<v>_uts<v> param_id."""
    import re
    lp_match = re.search(r"lp(-?[0-9.]+)", param_id)
    uts_match = re.search(r"uts([0-9.]+)", param_id)
    lp = float(lp_match.group(1)) if lp_match else -200.0
    uts = float(uts_match.group(1)) if uts_match else 5.0
    return lp, uts


_PARAM_IDS_ALL_TOOLS = {
    "fastder": PARAM_IDS,
    "derfinder": _baseline_mc_pt_param_ids(),
    "megadepth_baseline": _baseline_mc_param_ids(),
    "grohmm": _baseline_lp_uts_param_ids(),
}
# Restrict to the tools actually selected (see TOOLS above).
PARAM_IDS_BY_TOOL = {t: _PARAM_IDS_ALL_TOOLS[t] for t in TOOLS}


def expand_tool_paths(template, **fixed):
    """Expand a path template with one (tool, param_id) entry per tool's
    own param grid, plus any fixed kwargs (sample, scenario)."""
    out = []
    for tool, pids in PARAM_IDS_BY_TOOL.items():
        for pid in pids:
            out.extend(expand(template, tool=tool, param_id=pid, **fixed))
    return out


def expand_eval_paths(template):
    """Expand an evaluation-output template over every tool and param grid,
    every scenario, and the samples that belong to that scenario. Used by the
    collect rules so the recount3 backend, whose groups hold different
    samples, does not get an incorrect scenario-by-sample cross-product."""
    out = []
    for scenario in SCENARIOS:
        for sample in SAMPLES_BY_SCENARIO[scenario]:
            out.extend(expand_tool_paths(template, scenario=scenario, sample=sample))
    return out


