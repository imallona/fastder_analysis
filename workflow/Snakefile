import os
import itertools
from pathlib import Path

configfile: "../config/config.yaml"

# Internal path constants
WORKFLOW_DIR = Path(workflow.basedir)
DATA_DIR = WORKFLOW_DIR / "data"
LOG_DIR = WORKFLOW_DIR / "logs"

# Monorail
MONORAIL_EXTERNAL = WORKFLOW_DIR / "external" / "monorail-external"
MONORAIL_REF_DIR = DATA_DIR / "monorail_refs"

# Singularity images
CONTAINERS_DIR = WORKFLOW_DIR / "containers"
PUMP_SIF = str(CONTAINERS_DIR / "recount-pump-1.1.3.sif")
UNIFY_SIF = str(CONTAINERS_DIR / "recount-unify-1.1.1.sif")

# fastder
FASTDER_DIR = DATA_DIR / "fastder"
FASTDER_BUILD_DIR = WORKFLOW_DIR / "external" / "fastder" / "build"
RESULTS_DIR = WORKFLOW_DIR / "results"

# Experimental design
ASIM_SAMPLES = list(config["asimulator"]["samples"].keys())

# Pump source determines which samples and inputs the pump rule uses
PUMP_SOURCE = config["monorail"]["pump_source"]
if PUMP_SOURCE == "asimulator":
    PUMP_SAMPLES = ASIM_SAMPLES
    LABEL_EXT = ".gff3"  # ASimulatoR always produces GFF3
elif PUMP_SOURCE == "sra":
    PUMP_SAMPLES = list(config["monorail"]["sra_samples"].keys())
    ref_ann = config.get("gffcompare", {}).get("reference_annotation", "")
    LABEL_EXT = Path(ref_ann).suffix if ref_ann else ".gff3"
else:
    raise ValueError(f"Unknown pump_source: '{PUMP_SOURCE}'. Must be 'asimulator' or 'sra'.")

# fastder parameter grid: every combination of the configured lists is run.
# Each combo is a plain dict of {param_name: value} for explicitly-set params only.
# Omitted params are not passed to fastder, which uses its own internal defaults.
FASTDER_CFG = config.get("fastder") or {}
STRANDED = FASTDER_CFG.get("stranded", False)

# Maps each parameter name to its (id_abbreviation, CLI flag).
_PARAM_SPEC = {
    "min_coverage":       ("mc", "--min-coverage"),
    "min_length":         ("ml", "--min-length"),
    "position_tolerance": ("pt", "--position-tolerance"),
    "coverage_tolerance": ("ct", "--coverage-tolerance"),
}

# Cross-product of all configured value lists; {} means "run once with all defaults".
_grid_axes = [
    [(key, val) for val in FASTDER_CFG[key]]
    for key in _PARAM_SPEC
    if key in FASTDER_CFG
]
_PARAM_COMBOS = [dict(items) for items in itertools.product(*_grid_axes)] if _grid_axes else [{}]


def _param_id(combo):
    """Short, directory-safe identifier for a parameter combination."""
    abbr = {k: spec[0] for k, spec in _PARAM_SPEC.items()}
    parts = [f"{abbr[k]}{v}" for k, v in combo.items()]
    return "_".join(parts) if parts else "default"


def _fastder_cli_args(combo):
    """CLI flags to pass to fastder for this combination (only explicitly-set params)."""
    flag = {k: spec[1] for k, spec in _PARAM_SPEC.items()}
    return " ".join(f"{flag[k]} {v}" for k, v in combo.items())


PARAM_IDS = [_param_id(c) for c in _PARAM_COMBOS]
PARAM_CLI_ARGS = {_param_id(c): _fastder_cli_args(c) for c in _PARAM_COMBOS}
# For the summary CSV: the explicit params for each run
PARAM_DICT = {_param_id(c): c for c in _PARAM_COMBOS}


def pump_input(wildcards):
    """Return file inputs for the pump rule.
    Local sources declare the asim directory so Snakemake tracks the dependency.
    SRA sources have no file inputs as data is downloaded at runtime.
    """
    if PUMP_SOURCE == "asimulator":
        return {"sample_dir": str(DATA_DIR / "asim" / wildcards.sample)}
    return {}


rule all:
    input:
        str(RESULTS_DIR / "summary.csv")
    default_target: True


# 1. Download reference
# Uses fastder.chromosomes from config to restrict which chromosomes are
# downloaded.  When chromosomes is omitted (or empty), all (1-22, X) are
# fetched — matching fastder's own --chr default.
rule download_reference:
    output:
        directory("data/reference/Homo_sapiens_GRCh38_Ensembl115")
    log:
        str(LOG_DIR / "download_reference.log")
    params:
        chr_args=" ".join(str(c) for c in FASTDER_CFG["chromosomes"])
            if FASTDER_CFG.get("chromosomes")
            else "",
    conda:
        "envs/reference_download.yaml"
    shell:
        "bash scripts/download_reference_ensembl.sh '{output}' {params.chr_args} > {log} 2>&1"


# 2. Run ASimulatoR
rule run_asimulator:
    input:
        reference=rules.download_reference.output[0]
    output:
        directory(str(DATA_DIR / "asim" / "{sample}"))
    log:
        str(LOG_DIR / "asimulator" / "{sample}.log")
    params:
        outdir=lambda wc: str(DATA_DIR / "asim" / wc.sample),
        events=lambda wc: config["asimulator"]["samples"][wc.sample],
        seq_depth=config["asimulator"]["seq_depth"],
        multi_events_per_exon=config["asimulator"]["multi_events_per_exon"],
        strand_specific=config["asimulator"]["strand_specific"],
        probs_as_freq=config["asimulator"]["probs_as_freq"],
        seed=config["seed"],
        ncores=config["cores"],
    container:
        "docker://biomedbigdata/asimulator"
    script:
        "scripts/runASimulatoR.R"


# 3. Pull Singularity containers
rule pull_containers:
    output:
        pump=PUMP_SIF,
        unify=UNIFY_SIF,
    log:
        str(LOG_DIR / "pull_containers.log")
    shell:
        """
        mkdir -p {CONTAINERS_DIR}
        singularity pull --name {output.pump} docker://quay.io/broadsword/recount-pump:1.1.3 > {log} 2>&1
        singularity pull --name {output.unify} docker://quay.io/broadsword/recount-unify:1.1.1 >> {log} 2>&1
        """


# 4. Download Monorail reference indexes
rule download_monorail_refs:
    output:
        touch(str(MONORAIL_REF_DIR / "refs.DONE"))
    params:
        ref_version=config["monorail"]["ref_version"],
    shell:
        """
        mkdir -p {MONORAIL_REF_DIR}
        cd {MONORAIL_REF_DIR}
        bash {MONORAIL_EXTERNAL}/get_human_ref_indexes.sh
        bash {MONORAIL_EXTERNAL}/get_unify_refs.sh {params.ref_version}
        """


# 5. Run recount-pump per sample
# Input source is controlled by monorail.pump_source in config.yaml:
#   asimulator: reads FASTQs from the run_asimulator output directories
#   sra:        downloads reads from SRA at runtime using the run/study accessions
#               defined in monorail.sra_samples
rule pump:
    input:
        unpack(pump_input),
        container=PUMP_SIF,
        refs=str(MONORAIL_REF_DIR / "refs.DONE"),
    output:
        directory(str(DATA_DIR / "pump" / "{sample}"))
    log:
        str(LOG_DIR / "pump" / "{sample}.log")
    params:
        ref_version=config["monorail"]["ref_version"],
        ref_path=str(MONORAIL_REF_DIR),
        ncores=config["cores"],
        pump_script=str(MONORAIL_EXTERNAL / "singularity" / "run_recount_pump.sh"),
        project_name=config["monorail"]["project_name"],
    run:
        os.makedirs(output[0], exist_ok=True)
        if PUMP_SOURCE == "asimulator":
            fp1 = str(DATA_DIR / "asim" / wildcards.sample / "sample_01_1.fastq")
            fp2 = str(DATA_DIR / "asim" / wildcards.sample / "sample_01_2.fastq")
            shell(
                "WORKING_DIR={output[0]}"
                " bash {params.pump_script}"
                " {input.container}"
                " {wildcards.sample}"
                " local"
                " {params.ref_version}"
                " {params.ncores}"
                " {params.ref_path}"
                f" {fp1}"
                f" {fp2}"
                " {params.project_name}"
                " > {log} 2>&1"
            )
        else:
            # TODO: test this part
            sample_cfg = config["monorail"]["sra_samples"][wildcards.sample]
            study_acc = sample_cfg["study_acc"]
            shell(
                "WORKING_DIR={output[0]}"
                " bash {params.pump_script}"
                " {input.container}"
                " {wildcards.sample}"
                f" {study_acc}"
                " {params.ref_version}"
                " {params.ncores}"
                " {params.ref_path}"
                " > {log} 2>&1"
            )


# 6. Recount-unify: aggregate all pump outputs
rule unify:
    input:
        pump_dirs=expand(str(DATA_DIR / "pump" / "{sample}"), sample=PUMP_SAMPLES),
        container=UNIFY_SIF,
        refs=str(MONORAIL_REF_DIR / "refs.DONE"),
    output:
        directory(str(DATA_DIR / "unify")),
        str(DATA_DIR / "sample_metadata.tsv"),
    log:
        str(LOG_DIR / "unify.log")
    params:
        ref_version=config["monorail"]["ref_version"],
        ref_path=str(MONORAIL_REF_DIR),
        project="{short}:{pid}".format(
            short=config["monorail"]["project_name"],
            pid=config["monorail"]["project_id"],
        ),
        ncores=config["cores"],
        unify_script=str(MONORAIL_EXTERNAL / "singularity" / "run_recount_unify.sh"),
        pump_parent=str(DATA_DIR / "pump"),
    run:
        os.makedirs(output[0], exist_ok=True)

        # Build the sample metadata (study_id<TAB>sample_id, with header).
        # study_id must match what pump encoded in its output filenames:
        #   asimulator: pump was called with project_name as actual_study -> filenames: sample!project_name!...
        #   sra:        pump was called with per-sample study_acc         -> filenames: sample!study_acc!...
        if PUMP_SOURCE == "asimulator":
            rows = [(config["monorail"]["project_name"], s) for s in PUMP_SAMPLES]
        else:
            rows = [(config["monorail"]["sra_samples"][s]["study_acc"], s) for s in PUMP_SAMPLES]
        with open(output[1], "w") as fh:
            fh.write("study_id\tsample_id\n")
            fh.writelines(f"{study}\t{sample}\n" for study, sample in rows)

        shell(
            "bash {params.unify_script}"
            " {input.container}"
            " {params.ref_version}"
            " {params.ref_path}"
            " {output[0]}"
            " {params.pump_parent}"
            " {output[1]}"
            " {params.ncores}"
            " {params.project}"
            " > {log} 2>&1"
        )


# 7a. Generate strand-specific BigWigs from pump BAM output.
# Uses bedtools genomecov to compute per-base coverage split by alignment strand,
# then converts to BigWig.  The -split flag ensures only aligned bases (not
# intron spans) are counted, matching megadepth's coverage semantics.
# -F 256 excludes secondary alignments (same as megadepth).
rule generate_stranded_bigwigs:
    input:
        pump_dir=str(DATA_DIR / "pump" / "{sample}"),
    output:
        plus_bw=str(DATA_DIR / "stranded_bigwigs" / "{sample}.plus.bw"),
        minus_bw=str(DATA_DIR / "stranded_bigwigs" / "{sample}.minus.bw"),
    log:
        str(LOG_DIR / "stranded_bigwigs" / "{sample}.log")
    params:
        bam=lambda wc: str(
            DATA_DIR / "pump" / wc.sample / "output" / f"{wc.sample}_att0"
            / "{}!{}!{}!local~sorted.bam".format(
                wc.sample,
                config["monorail"]["project_name"] if PUMP_SOURCE == "asimulator"
                    else config["monorail"]["sra_samples"][wc.sample]["study_acc"],
                config["monorail"]["ref_version"],
            )
        ),
        chrom_sizes=lambda wc: str(DATA_DIR / "stranded_bigwigs" / f"{wc.sample}.chrom.sizes"),
    conda:
        "envs/stranded_bigwig.yaml"
    shell:
        """
        bam="{params.bam}"

        # Index BAM if needed
        if [ ! -f "${{bam}}.bai" ]; then
            samtools index "$bam" >> {log} 2>&1
        fi

        # Get chromosome sizes from BAM header
        samtools idxstats "$bam" | awk '$2 > 0 {{print $1"\\t"$2}}' > {params.chrom_sizes} 2>> {log}

        # Plus strand: -F 256 excludes secondary alignments, -split respects CIGAR
        # -bga includes zero-coverage regions (required by fastder's Averager which
        # expects all samples to have identical per-chromosome vector lengths)
        samtools view -u -F 256 "$bam" \
            | bedtools genomecov -ibam stdin -bga -split -strand '+' \
            > {output.plus_bw}.unsorted.bg 2>> {log}
        sort -k1,1 -k2,2n {output.plus_bw}.unsorted.bg > {output.plus_bw}.bg 2>> {log}
        bedGraphToBigWig {output.plus_bw}.bg {params.chrom_sizes} {output.plus_bw} >> {log} 2>&1
        rm -f {output.plus_bw}.unsorted.bg {output.plus_bw}.bg

        # Minus strand
        samtools view -u -F 256 "$bam" \
            | bedtools genomecov -ibam stdin -bga -split -strand '-' \
            > {output.minus_bw}.unsorted.bg 2>> {log}
        sort -k1,1 -k2,2n {output.minus_bw}.unsorted.bg > {output.minus_bw}.bg 2>> {log}
        bedGraphToBigWig {output.minus_bw}.bg {params.chrom_sizes} {output.minus_bw} >> {log} 2>&1
        rm -f {output.minus_bw}.unsorted.bg {output.minus_bw}.bg
        """


# 7b. Extract and organise all inputs that fastder needs into a flat directory
rule extract_fastder_inputs:
    input:
        unify_dir=str(DATA_DIR / "unify"),
        pump_dirs=expand(str(DATA_DIR / "pump" / "{sample}"), sample=PUMP_SAMPLES),
        stranded_bws=(
            expand(
                [str(DATA_DIR / "stranded_bigwigs" / "{sample}.plus.bw"),
                 str(DATA_DIR / "stranded_bigwigs" / "{sample}.minus.bw")],
                sample=PUMP_SAMPLES,
            ) if STRANDED else []
        ),
    output:
        touch(str(FASTDER_DIR / "extract.DONE"))
    log:
        str(LOG_DIR / "extract_fastder_inputs.log")
    params:
        fastder_dir=str(FASTDER_DIR),
        pump_dir=str(DATA_DIR / "pump"),
        project_name=config["monorail"]["project_name"],
        ref_version=config["monorail"]["ref_version"],
        stranded=STRANDED,
        stranded_bw_dir=str(DATA_DIR / "stranded_bigwigs"),
        samples_tsv_script=str(WORKFLOW_DIR / "scripts" / "create_bigwig_list.sh"),
    run:
        import shutil, gzip

        fdir = Path(params.fastder_dir)
        fdir.mkdir(parents=True, exist_ok=True)

        # 1. Gunzip MM and RR files from unify output
        project = params.project_name
        # Unify puts junction files under junction_counts_per_study/al/<study>/
        # Find files dynamically instead of hardcoding the low-order directory
        jct_base = Path(input.unify_dir) / "junction_counts_per_study"
        mm_gz = rr_gz = None
        for gz in jct_base.rglob(f"*.ALL.MM.gz"):
            mm_gz = gz
        for gz in jct_base.rglob(f"*.ALL.RR.gz"):
            rr_gz = gz

        if not mm_gz or not rr_gz:
            raise FileNotFoundError(
                f"Could not find ALL.MM.gz / ALL.RR.gz under {jct_base}"
            )

        for gz_path, suffix in [(mm_gz, ".ALL.MM"), (rr_gz, ".ALL.RR")]:
            out_name = gz_path.name.removesuffix(".gz")
            with gzip.open(gz_path, "rb") as f_in, open(fdir / out_name, "wb") as f_out:
                shutil.copyfileobj(f_in, f_out)

        # 2. Copy BigWig files into fastder directory
        if params.stranded:
            # Strand-specific BigWigs from generate_stranded_bigwigs rule
            bw_dir = Path(params.stranded_bw_dir)
            for sample in PUMP_SAMPLES:
                for strand in ("plus", "minus"):
                    bw_src = bw_dir / f"{sample}.{strand}.bw"
                    if not bw_src.exists():
                        raise FileNotFoundError(f"Stranded BigWig not found: {bw_src}")
                    shutil.copy2(bw_src, fdir / f"{sample}.{strand}.bw")
        else:
            # Unstranded BigWigs directly from pump output
            for sample in PUMP_SAMPLES:
                att_dir = Path(params.pump_dir) / sample / "output" / f"{sample}_att0"
                if PUMP_SOURCE == "asimulator":
                    study = project
                else:
                    study = config["monorail"]["sra_samples"][sample]["study_acc"]
                bw_name = f"{sample}!{study}!{params.ref_version}!local.all.bw"
                bw_src = att_dir / bw_name
                if not bw_src.exists():
                    raise FileNotFoundError(f"BigWig not found: {bw_src}")
                shutil.copy2(bw_src, fdir / f"{sample}.all.bw")

        # 3. Generate BigWig-list CSV from unify samples.tsv
        samples_tsv = Path(input.unify_dir) / "samples.tsv"
        bigwig_csv = fdir / "recount3_BigWig_list.csv"
        bw_mode = "stranded" if params.stranded else "unstranded"
        shell(
            "bash {params.samples_tsv_script}"
            f" {samples_tsv}"
            f" {bigwig_csv}"
            f" {bw_mode}"
            " >> {log} 2>&1"
        )

        # 4. Copy label / reference GFF for gffcompare
        if PUMP_SOURCE == "asimulator":
            for sample in PUMP_SAMPLES:
                gff_src = Path(str(DATA_DIR)) / "asim" / sample / "splicing_variants.gff3"
                if gff_src.exists():
                    shutil.copy2(gff_src, fdir / f"{sample}_label.gff3")
        else:
            # TODO: replace with recount3, SRA doesn't work
            ref_ann = config.get("gffcompare", {}).get("reference_annotation", "")
            if ref_ann:
                ref_path = Path(ref_ann)
                if not ref_path.is_absolute():
                    ref_path = Path(str(WORKFLOW_DIR)) / ref_ann
                if ref_path.exists():
                    for sample in PUMP_SAMPLES:
                        shutil.copy2(ref_path, fdir / f"{sample}_label{ref_path.suffix}")


# 8. Match chr prefix convention for files used by gffcompare
rule match_chr_prefix:
    input:
        str(FASTDER_DIR / "extract.DONE")
    output:
        touch(str(FASTDER_DIR / "match_chr_prefix.DONE"))
    log:
        str(LOG_DIR / "match_chr_prefix.log")
    params:
        fastder_dir=str(FASTDER_DIR),
    shell:
        """
        for file in {params.fastder_dir}/*_label.gff3 {params.fastder_dir}/*_label.gtf; do
            [ -f "$file" ] || continue
            tmp="${{file}}.tmp"
            awk 'BEGIN{{FS=OFS="\\t"}}
                /^#/ {{ print; next }}
                $1 !~ /^chr/ {{ $1 = "chr" $1 }}
                {{ print }}
            ' "$file" > "$tmp"
            mv "$tmp" "$file"
        done > {log} 2>&1
        """


# 9. Convert BigWig to BedGraph
rule bigwig_to_bedgraph:
    input:
        str(FASTDER_DIR / "extract.DONE")
    output:
        touch(str(FASTDER_DIR / "convert_bedgraph.DONE"))
    log:
        str(LOG_DIR / "bigwig_to_bedgraph.log")
    params:
        fastder_dir=str(FASTDER_DIR),
    conda:
        "envs/ucsc_tools.yaml"
    shell:
        """
        for bw in {params.fastder_dir}/*.bw; do
            [ -f "$bw" ] || continue
            out="${{bw%.bw}}.bedGraph"
            bigWigToBedGraph "$bw" "$out"
        done > {log} 2>&1
        """


# 10. Build fastder from source
rule build_fastder:
    output:
        str(FASTDER_BUILD_DIR / "fastder")
    log:
        str(LOG_DIR / "build_fastder.log")
    params:
        fastder_src=str(WORKFLOW_DIR / "external" / "fastder"),
        build_script=str(WORKFLOW_DIR / "external" / "fastder" / "conda" / "recipe" / "build.sh"),
    conda:
        "envs/fastder_build.yaml"
    shell:
        """
        cd {params.fastder_src}
        bash {params.build_script} > {log} 2>&1
        """


# 11. Run fastder for each parameter combination.
# Each run gets its own working directory (data/fastder/runs/{param_id}/) with
# symlinks to the shared inputs. This allows parallel execution without races on
# the FASTDER_RESULT_*.gtf output filenames.
rule run_fastder:
    input:
        fastder_exe=str(FASTDER_BUILD_DIR / "fastder"),
        bedgraph_done=str(FASTDER_DIR / "convert_bedgraph.DONE"),
    output:
        gtf_path=str(FASTDER_DIR / "run_fastder_{param_id}.gtf_path"),
        done=touch(str(FASTDER_DIR / "run_fastder_{param_id}.DONE")),
    log:
        str(LOG_DIR / "run_fastder" / "{param_id}.log")
    params:
        fastder_dir=str(FASTDER_DIR),
        run_dir=lambda wc: str(FASTDER_DIR / "runs" / wc.param_id),
        ncores=config["cores"],
        fastder_args=lambda wc: PARAM_CLI_ARGS[wc.param_id],
        stranded_arg="--stranded" if STRANDED else "",
        chr_args=(
            "--chr " + " ".join(str(c) for c in FASTDER_CFG["chromosomes"])
            if FASTDER_CFG.get("chromosomes")
            else ""
        ),
    conda:
        "envs/fastder_build.yaml"
    shell:
        """
        mkdir -p {params.run_dir}
        # Symlink all shared inputs into the private run directory
        for f in {params.fastder_dir}/*.bedGraph \
                  {params.fastder_dir}/*.MM \
                  {params.fastder_dir}/*.RR \
                  {params.fastder_dir}/*.csv; do
            [ -e "$f" ] || continue
            ln -sf "$f" {params.run_dir}/
        done
        {input.fastder_exe} \
            --dir {params.run_dir} \
            {params.stranded_arg} \
            {params.fastder_args} \
            --cores {params.ncores} \
            {params.chr_args} \
            > {log} 2>&1
        gtf=$(ls {params.run_dir}/FASTDER_RESULT_*.gtf 2>/dev/null)
        if [ -z "$gtf" ]; then
            echo "ERROR: fastder did not produce a FASTDER_RESULT_*.gtf" >&2; exit 1
        fi
        echo "$gtf" > {output.gtf_path}
        """


# 12. Run gffcompare for each sample x parameter combination
rule run_gffcompare:
    input:
        chr_prefix_done=str(FASTDER_DIR / "match_chr_prefix.DONE"),
        gtf_path=str(FASTDER_DIR / "run_fastder_{param_id}.gtf_path"),
    output:
        stats=str(RESULTS_DIR / "{sample}" / "{param_id}" / "gffcompare.stats"),
    log:
        str(LOG_DIR / "gffcompare" / "{sample}_{param_id}.log")
    params:
        label_gff=lambda wc: str(FASTDER_DIR / f"{wc.sample}_label{LABEL_EXT}"),
        out_prefix=lambda wc: os.path.join(
            str(RESULTS_DIR), wc.sample, wc.param_id, "gffcompare",
        ),
    conda:
        "envs/gffcompare.yaml"
    shell:
        """
        fastder_gtf=$(cat {input.gtf_path})
        mkdir -p $(dirname {params.out_prefix})
        gffcompare -r {params.label_gff} -o {params.out_prefix} "$fastder_gtf" > {log} 2>&1
        """


# 13. Collect all gffcompare stats into a summary CSV
rule collect_results:
    input:
        expand(
            str(RESULTS_DIR / "{sample}" / "{param_id}" / "gffcompare.stats"),
            sample=PUMP_SAMPLES,
            param_id=PARAM_IDS,
        ),
    output:
        str(RESULTS_DIR / "summary.csv"),
    run:
        import csv
        import re

        def parse_base_level(stats_file):
            """Extract Base level Sensitivity and Precision from a .stats file."""
            with open(stats_file) as f:
                for line in f:
                    m = re.match(
                        r"^\s*Base level\s*:\s*(\d+\.\d+)\s*\|\s*(\d+\.\d+)",
                        line,
                    )
                    if m:
                        return m.group(1), m.group(2)
            return "", ""

        rows = []
        for stats_file in input:
            parts = Path(stats_file).parts
            pid = parts[-2]
            sample = parts[-3]
            sensitivity, precision = parse_base_level(stats_file)
            row = {"sample": sample, "param_id": pid}
            row.update(PARAM_DICT.get(pid, {}))
            row["sensitivity"] = sensitivity
            row["precision"] = precision
            rows.append(row)

        # Column order: sample, param_id, any grid params that were set, metrics
        param_cols = sorted({k for r in rows for k in r if k not in
                            {"sample", "param_id", "sensitivity", "precision"}})
        fieldnames = ["sample", "param_id"] + param_cols + ["sensitivity", "precision"]

        with open(output[0], "w", newline="") as f:
            writer = csv.DictWriter(f, fieldnames=fieldnames)
            writer.writeheader()
            for row in sorted(rows, key=lambda r: (r["sample"], r["param_id"])):
                writer.writerow(row)
